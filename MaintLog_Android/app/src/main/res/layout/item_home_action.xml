<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">
    <data>
        <variable
            name="item"
            type="com.github.domain.model.action.ActionData" />
    </data>

    <LinearLayout
        android:id="@+id/item_home_action"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/pretendard_semibold"
            android:text="로그인 문제 발생"
            android:textColor="@color/primaryBlack"
            android:textSize="@dimen/content_18" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/margin_12dp"
            android:text="진행중"
            android:textColor="@color/primaryDarkGray"
            android:textSize="@dimen/content_16" />

        <TextView
            android:layout_width="72dp"
            android:layout_height="34dp"
            android:background="@color/primaryGray"
            android:fontFamily="@font/pretendard_semibold"
            android:gravity="center"
            android:text="진행중"
            android:textColor="@color/white"
            android:textSize="@dimen/content_16" />
    </LinearLayout>
</layout>