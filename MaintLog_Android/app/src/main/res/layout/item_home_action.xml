<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <import type="com.github.domain.model.common.StatusType" />

        <variable
            name="item"
            type="com.github.domain.model.action.ActionData" />

    </data>

    <LinearLayout
        android:id="@+id/item_home_action"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:foreground="?attr/selectableItemBackground">

        <!-- 아이템 내용 -->
        <LinearLayout
            android:id="@+id/layout_action_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="72dp"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">

            <!-- 상단: 상태 | 제목 | 일시 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.github.maintlog_android.view.common.StatusBadgeView
                    android:id="@+id/tv_action_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:statusType="@{StatusType.PROGRESS}" />

                <TextView
                    android:id="@+id/tv_action_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/pretendard_semibold"
                    android:maxLines="1"
                    android:text="로그인 문제 발생"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="@dimen/content_16" />

                <TextView
                    android:id="@+id/tv_action_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="@font/pretendard_medium"
                    android:text="14:32"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="@dimen/content_12" />

            </LinearLayout>

            <!-- 하단: 내용 | > -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_action_content"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/pretendard_medium"
                    android:maxLines="1"
                    android:text="사용자 로그인 실패 현상 발생"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="@dimen/content_14" />

                <ImageView
                    android:id="@+id/iv_action_arrow"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="12dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="@color/colorTextSecondary" />

            </LinearLayout>

        </LinearLayout>

        <!-- 실선 Divider -->
        <View
            android:id="@+id/view_action_divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@color/colorDivider" />

    </LinearLayout>

</layout>