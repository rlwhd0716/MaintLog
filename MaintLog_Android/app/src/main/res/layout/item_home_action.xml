<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>

        <variable
            name="item"
            type="com.github.domain.model.action.ActionData" />

    </data>

    <LinearLayout
        android:id="@+id/item_home_action"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="78dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="18dp"
        android:paddingVertical="14dp">

        <!-- 좌측 상태 표시 -->
        <LinearLayout
            android:layout_width="58dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/bg_circle_status_progress" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_status_progress"
                android:fontFamily="@font/pretendard_semibold"
                android:gravity="center"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="진행중"
                android:textColor="@color/colorInfo"
                android:textSize="@dimen/content_12" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="14dp"
            android:background="@color/colorDivider" />

        <!-- 내용 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_action_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/pretendard_semibold"
                android:maxLines="1"
                android:text="로그인 문제 발생"
                android:textColor="@color/colorTextPrimary"
                android:textSize="@dimen/content_18" />

            <TextView
                android:id="@+id/tv_action_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="사용자 로그인 실패 현상 발생"
                android:textColor="@color/colorTextSecondary"
                android:textSize="@dimen/content_14" />
        </LinearLayout>

        <!-- 우측 화살표 -->
        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginStart="10dp"
            android:src="@drawable/ic_arrow_right"
            android:tint="@color/colorTextSecondary" />

    </LinearLayout>

</layout>