<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:orientation="vertical"
        tools:context=".view.main.MainActivity">

        <com.github.util.ui.CustomTitleView
            android:id="@+id/title_request"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:itemTitleText="요청사항" />

        <FrameLayout
            android:id="@+id/content_request"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.core.widget.NestedScrollView
                android:id="@+id/scroll_request"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:fillViewport="true"
                android:paddingBottom="112dp">

                <LinearLayout
                    android:id="@+id/container_request"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/layout_request_filter"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/rvItemSubColor"
                        android:orientation="horizontal"
                        android:padding="@dimen/padding_12dp">

                        <TextView
                            android:id="@+id/tv_request_filter_all"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:background="@color/primaryGray"
                            android:fontFamily="@font/pretendard_semibold"
                            android:gravity="center"
                            android:text="전체"
                            android:textColor="@color/white"
                            android:textSize="@dimen/content_18" />

                        <TextView
                            android:id="@+id/tv_request_filter_in_progress"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="1dp"
                            android:layout_weight="1"
                            android:background="@color/white"
                            android:fontFamily="@font/pretendard_semibold"
                            android:gravity="center"
                            android:text="진행중"
                            android:textColor="@color/primaryBlack"
                            android:textSize="@dimen/content_18" />

                        <TextView
                            android:id="@+id/tv_request_filter_completed"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="1dp"
                            android:layout_weight="1"
                            android:background="@color/white"
                            android:fontFamily="@font/pretendard_semibold"
                            android:gravity="center"
                            android:text="완료"
                            android:textColor="@color/primaryBlack"
                            android:textSize="@dimen/content_18" />

                        <TextView
                            android:id="@+id/tv_request_filter_hold"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="1dp"
                            android:layout_weight="1"
                            android:background="@color/white"
                            android:fontFamily="@font/pretendard_semibold"
                            android:gravity="center"
                            android:text="보류"
                            android:textColor="@color/primaryBlack"
                            android:textSize="@dimen/content_18" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/list_request"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="@dimen/padding_16dp">

                        <LinearLayout
                            android:id="@+id/item_request_login_error"
                            android:layout_width="match_parent"
                            android:layout_height="92dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tv_request_login_title"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/pretendard_semibold"
                                    android:text="로그인 문제 발생"
                                    android:textColor="@color/primaryBlack"
                                    android:textSize="@dimen/content_20" />

                                <TextView
                                    android:id="@+id/tv_request_login_meta"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/margin_8dp"
                                    android:text="2026-04-12   홍길동"
                                    android:textColor="@color/primaryDarkGray"
                                    android:textSize="@dimen/content_16" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tv_request_login_status"
                                android:layout_width="78dp"
                                android:layout_height="36dp"
                                android:background="@color/primaryGray"
                                android:fontFamily="@font/pretendard_semibold"
                                android:gravity="center"
                                android:text="진행중"
                                android:textColor="@color/white"
                                android:textSize="@dimen/content_16" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/primaryLightGray" />

                        <LinearLayout
                            android:id="@+id/item_request_payment_error"
                            android:layout_width="match_parent"
                            android:layout_height="92dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tv_request_payment_title"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/pretendard_semibold"
                                    android:text="결제 시스템 오류"
                                    android:textColor="@color/primaryBlack"
                                    android:textSize="@dimen/content_20" />

                                <TextView
                                    android:id="@+id/tv_request_payment_meta"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/margin_8dp"
                                    android:text="2026-04-11   김철수"
                                    android:textColor="@color/primaryDarkGray"
                                    android:textSize="@dimen/content_16" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tv_request_payment_status"
                                android:layout_width="78dp"
                                android:layout_height="36dp"
                                android:background="@color/primaryGray"
                                android:fontFamily="@font/pretendard_semibold"
                                android:gravity="center"
                                android:text="진행중"
                                android:textColor="@color/white"
                                android:textSize="@dimen/content_16" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/primaryLightGray" />

                        <LinearLayout
                            android:id="@+id/item_request_data_fix"
                            android:layout_width="match_parent"
                            android:layout_height="92dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tv_request_data_title"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/pretendard_semibold"
                                    android:text="데이터 오류 수정"
                                    android:textColor="@color/primaryBlack"
                                    android:textSize="@dimen/content_20" />

                                <TextView
                                    android:id="@+id/tv_request_data_meta"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/margin_8dp"
                                    android:text="2026-04-10   김영희"
                                    android:textColor="@color/primaryDarkGray"
                                    android:textSize="@dimen/content_16" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tv_request_data_status"
                                android:layout_width="78dp"
                                android:layout_height="36dp"
                                android:background="@color/primaryGray"
                                android:fontFamily="@font/pretendard_semibold"
                                android:gravity="center"
                                android:text="완료"
                                android:textColor="@color/white"
                                android:textSize="@dimen/content_16" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/primaryLightGray" />

                        <LinearLayout
                            android:id="@+id/item_request_api_delay"
                            android:layout_width="match_parent"
                            android:layout_height="92dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tv_request_api_title"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/pretendard_semibold"
                                    android:text="API 속도 지연"
                                    android:textColor="@color/primaryBlack"
                                    android:textSize="@dimen/content_20" />

                                <TextView
                                    android:id="@+id/tv_request_api_meta"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/margin_8dp"
                                    android:text="2026-04-09   박민수"
                                    android:textColor="@color/primaryDarkGray"
                                    android:textSize="@dimen/content_16" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tv_request_api_status"
                                android:layout_width="78dp"
                                android:layout_height="36dp"
                                android:background="@color/primaryGray"
                                android:fontFamily="@font/pretendard_semibold"
                                android:gravity="center"
                                android:text="보류"
                                android:textColor="@color/white"
                                android:textSize="@dimen/content_16" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/primaryLightGray" />

                        <LinearLayout
                            android:id="@+id/item_request_ui_design"
                            android:layout_width="match_parent"
                            android:layout_height="92dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tv_request_ui_title"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/pretendard_semibold"
                                    android:text="UI 디자인 개선 요청"
                                    android:textColor="@color/primaryBlack"
                                    android:textSize="@dimen/content_20" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tv_request_ui_status"
                                android:layout_width="78dp"
                                android:layout_height="36dp"
                                android:background="@color/primaryGray"
                                android:fontFamily="@font/pretendard_semibold"
                                android:gravity="center"
                                android:text="등록"
                                android:textColor="@color/white"
                                android:textSize="@dimen/content_16" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <!-- TODO: 디자인 아이콘 리소스 확정 시 placeholder drawable 교체. -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_request_add"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="@dimen/margin_24dp"
                android:layout_marginBottom="@dimen/margin_24dp"
                android:contentDescription="요청 등록"
                app:backgroundTint="@color/primaryGray"
                app:srcCompat="@android:drawable/ic_input_add"
                app:tint="@color/white" />
        </FrameLayout>
    </LinearLayout>
</layout>
