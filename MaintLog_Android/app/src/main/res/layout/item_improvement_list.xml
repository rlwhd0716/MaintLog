<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">
    <data>

        <variable
            name="item"
            type="com.github.domain.model.improvement.ImprovementDetailData" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/item_request_login_error"
            android:layout_width="match_parent"
            android:layout_height="92dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_request_login_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/pretendard_semibold"
                    android:text="로그인 문제 발생"
                    android:textColor="@color/primaryBlack"
                    android:textSize="@dimen/content_20" />

                <TextView
                    android:id="@+id/tv_request_login_meta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_8dp"
                    android:text="2026-04-12   홍길동"
                    android:textColor="@color/primaryDarkGray"
                    android:textSize="@dimen/content_16" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_request_login_status"
                android:layout_width="78dp"
                android:layout_height="36dp"
                android:background="@color/primaryGray"
                android:fontFamily="@font/pretendard_semibold"
                android:gravity="center"
                android:text="진행중"
                android:textColor="@color/white"
                android:textSize="@dimen/content_16" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/primaryLightGray" />
    </LinearLayout>
</layout>