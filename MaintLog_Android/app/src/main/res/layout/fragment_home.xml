<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="vm"
            type="com.github.maintlog_android.view.main.MainViewModel" />
    </data>

    <FrameLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/colorBackground"
            android:orientation="vertical"
            tools:context=".view.home.HomeFragment">

            <include layout="@layout/layout_top_search_bar" />

            <androidx.core.widget.NestedScrollView
                android:id="@+id/nsvHome"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true"
                android:overScrollMode="never">

                <LinearLayout
                    android:id="@+id/llHome"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingTop="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="96dp">

                    <!-- 날씨 카드 -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cvIncidentSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/colorSurface"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp"
                        app:strokeColor="@color/colorBorder"
                        app:strokeWidth="1dp">

                        <include layout="@layout/layout_weather_card" />

                    </com.google.android.material.card.MaterialCardView>

                    <!-- 최근 장애 -->
                    <LinearLayout
                        android:id="@+id/section_recent_incidents"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tv_recent_incidents_title"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/pretendard_semibold"
                                android:text="최근 장애"
                                android:textColor="@color/colorTextPrimary"
                                android:textSize="@dimen/content_22" />

                            <TextView
                                android:id="@+id/btn_more_incidents"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:drawableEnd="@drawable/ic_arrow_right"
                                android:drawablePadding="4dp"
                                android:fontFamily="@font/pretendard_medium"
                                android:text="더보기"
                                android:textColor="@color/colorTextSecondary"
                                android:textSize="@dimen/content_14" />
                        </LinearLayout>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/card_recent_incident"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            app:cardBackgroundColor="@color/colorSurface"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="2dp"
                            app:strokeColor="@color/colorBorder"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minHeight="112dp"
                                android:orientation="horizontal"
                                android:padding="16dp">

                                <LinearLayout
                                    android:layout_width="72dp"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:orientation="vertical">

                                    <ImageView
                                        android:id="@+id/iv_incident_status"
                                        android:layout_width="40dp"
                                        android:layout_height="40dp"
                                        android:src="@drawable/ic_warning_circle" />

                                    <TextView
                                        android:id="@+id/tv_incident_status"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="8dp"
                                        android:background="@drawable/bg_status_error"
                                        android:fontFamily="@font/pretendard_semibold"
                                        android:gravity="center"
                                        android:paddingStart="8dp"
                                        android:paddingTop="4dp"
                                        android:paddingEnd="8dp"
                                        android:paddingBottom="4dp"
                                        android:text="조치중"
                                        android:textColor="@color/colorError"
                                        android:textSize="@dimen/content_12" />
                                </LinearLayout>

                                <View
                                    android:layout_width="1dp"
                                    android:layout_height="match_parent"
                                    android:layout_marginStart="16dp"
                                    android:layout_marginEnd="16dp"
                                    android:background="@color/colorDivider" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center_vertical"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/tv_incident_title"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="@font/pretendard_semibold"
                                        android:text="서버 다운 장애"
                                        android:textColor="@color/colorTextPrimary"
                                        android:textSize="@dimen/content_20" />

                                    <TextView
                                        android:id="@+id/tv_incident_date"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="8dp"
                                        android:fontFamily="@font/pretendard_medium"
                                        android:text="2026-05-18 14:32"
                                        android:textColor="@color/colorTextSecondary"
                                        android:textSize="@dimen/content_14" />

                                    <TextView
                                        android:id="@+id/tv_incident_description"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="12dp"
                                        android:ellipsize="end"
                                        android:maxLines="2"
                                        android:text="DB 연결 실패로 인해 일부 서비스 접근이 불가능한 상태입니다."
                                        android:textColor="@color/colorTextSecondary"
                                        android:textSize="@dimen/content_14" />
                                </LinearLayout>

                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <!-- 최근 요청사항 -->
                    <LinearLayout
                        android:id="@+id/section_recent_requests"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tv_recent_requests_title"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/pretendard_semibold"
                                android:text="최근 요청사항"
                                android:textColor="@color/colorTextPrimary"
                                android:textSize="@dimen/content_22" />

                            <TextView
                                android:id="@+id/btn_more_requests"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:drawableEnd="@drawable/ic_arrow_right"
                                android:drawablePadding="4dp"
                                android:fontFamily="@font/pretendard_medium"
                                android:text="더보기"
                                android:textColor="@color/colorTextSecondary"
                                android:textSize="@dimen/content_14" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layout_request_summary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:background="@drawable/bg_request_summary"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:paddingVertical="14dp">

                            <!-- 진행중 -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="진행중"
                                    android:textColor="@color/colorTextSecondary"
                                    android:textSize="@dimen/content_14" />

                                <TextView
                                    android:id="@+id/tv_request_progress_count"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:fontFamily="@font/pretendard_semibold"
                                    android:text="5"
                                    android:textColor="@color/colorInfo"
                                    android:textSize="@dimen/content_22" />
                            </LinearLayout>

                            <!-- Divider -->
                            <View
                                android:layout_width="1dp"
                                android:layout_height="36dp"
                                android:background="@color/colorDivider" />

                            <!-- 완료 -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="완료"
                                    android:textColor="@color/colorTextSecondary"
                                    android:textSize="@dimen/content_14" />

                                <TextView
                                    android:id="@+id/tv_request_complete_count"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:fontFamily="@font/pretendard_semibold"
                                    android:text="2"
                                    android:textColor="@color/colorSuccess"
                                    android:textSize="@dimen/content_22" />
                            </LinearLayout>

                            <!-- Divider -->
                            <View
                                android:layout_width="1dp"
                                android:layout_height="36dp"
                                android:background="@color/colorDivider" />

                            <!-- 보류 -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="보류"
                                    android:textColor="@color/colorTextSecondary"
                                    android:textSize="@dimen/content_14" />

                                <TextView
                                    android:id="@+id/tv_request_hold_count"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:fontFamily="@font/pretendard_semibold"
                                    android:text="1"
                                    android:textColor="@color/colorNeutral"
                                    android:textSize="@dimen/content_22" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Request List Card -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/card_recent_requests"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            app:cardBackgroundColor="@color/colorSurface"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="2dp"
                            app:strokeColor="@color/colorBorder"
                            app:strokeWidth="1dp">

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rv_recent_requests"
                                bindAdapter="@{vm.improvementActionList}"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:adapter="@{vm.homeActionAdapter}"
                                android:clipToPadding="false"
                                android:paddingTop="4dp"
                                android:paddingBottom="4dp"
                                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                                tools:itemCount="3"
                                tools:listitem="@layout/item_home_action" />

                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </LinearLayout>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_home_add"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|bottom"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="24dp"
            android:contentDescription="등록"
            android:src="@drawable/ic_add"
            app:backgroundTint="@color/colorPrimary"
            app:tint="@color/white" />
    </FrameLayout>
</layout>
