<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="vm"
            type="com.github.maintlog_android.view.main.MainViewModel" />
    </data>

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:orientation="vertical"
        tools:context=".view.home.HomeFragment">

        <include layout="@layout/layout_top_search_bar" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nsvHome"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/llHome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cvIncidentSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="6dp"
                    app:cardElevation="1dp"
                    android:layout_margin="8dp"
                    app:strokeColor="@color/primaryLightGray"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical">

                        <include layout="@layout/layout_weather_card" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:id="@+id/section_recent_incidents"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_16dp"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/padding_16dp">

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_recent_incidents_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/pretendard_semibold"
                            android:text="최근 장애"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="@dimen/content_22" />

                        <TextView
                            android:id="@+id/btn_more_incidents"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableEnd="@drawable/ic_arrow_right"
                            android:drawablePadding="4dp"
                            android:fontFamily="@font/pretendard_medium"
                            android:text="더보기"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="@dimen/content_14" />
                    </LinearLayout>

                    <!-- Incident Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_recent_incident"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_12dp"
                        app:cardBackgroundColor="@color/colorSurface"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="2dp"
                        app:strokeColor="@color/colorBorder"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="110dp"
                            android:orientation="horizontal"
                            android:padding="18dp">

                            <!-- 상태 영역 -->
                            <LinearLayout
                                android:layout_width="72dp"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:orientation="vertical">

                                <ImageView
                                    android:id="@+id/iv_incident_status"
                                    android:layout_width="36dp"
                                    android:layout_height="36dp"
                                    android:src="@drawable/ic_warning_circle"
                                    android:tint="@color/colorError" />

                                <TextView
                                    android:id="@+id/tv_incident_status"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:background="@drawable/bg_status_error"
                                    android:fontFamily="@font/pretendard_semibold"
                                    android:gravity="center"
                                    android:paddingHorizontal="10dp"
                                    android:paddingVertical="4dp"
                                    android:text="조치중"
                                    android:textColor="@color/colorError"
                                    android:textSize="@dimen/content_13" />
                            </LinearLayout>

                            <!-- Divider -->
                            <View
                                android:layout_width="1dp"
                                android:layout_height="match_parent"
                                android:layout_marginHorizontal="16dp"
                                android:background="@color/colorDivider" />

                            <!-- 내용 -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tv_incident_title"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/pretendard_semibold"
                                    android:text="서버 다운 장애"
                                    android:textColor="@color/colorTextPrimary"
                                    android:textSize="@dimen/content_20" />

                                <TextView
                                    android:id="@+id/tv_incident_date"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:fontFamily="@font/pretendard_medium"
                                    android:text="2026-05-18 14:32"
                                    android:textColor="@color/colorTextSecondary"
                                    android:textSize="@dimen/content_14" />

                                <TextView
                                    android:id="@+id/tv_incident_description"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="12dp"
                                    android:ellipsize="end"
                                    android:maxLines="2"
                                    android:text="DB 연결 실패로 인해 일부 서비스 접근이 불가능한 상태입니다."
                                    android:textColor="@color/colorTextSecondary"
                                    android:textSize="@dimen/content_15" />
                            </LinearLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/section_recent_requests"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/padding_16dp"
                    android:paddingTop="@dimen/padding_16dp"
                    android:paddingBottom="@dimen/padding_12dp">

                    <TextView
                        android:id="@+id/tv_recent_requests_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/pretendard_semibold"
                        android:text="최근 요청사항"
                        android:textColor="@color/primaryBlack"
                        android:textSize="@dimen/content_20" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="@dimen/margin_12dp"
                        android:background="@color/primaryLightGray" />

                    <androidx.recyclerview.widget.RecyclerView
                        bindAdapter="@{vm.improvementActionList}"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:adapter="@{vm.homeActionAdapter}"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:itemCount="3"
                        tools:listitem="@layout/item_home_action" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_home_quick_actions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/padding_16dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_home_add_request"
                        android:layout_width="0dp"
                        android:layout_height="96dp"
                        android:layout_marginEnd="@dimen/margin_8dp"
                        android:layout_weight="1"
                        android:backgroundTint="@color/white"
                        android:drawableTop="@android:drawable/ic_input_add"
                        android:drawableTint="@color/primaryGray"
                        android:fontFamily="@font/pretendard_semibold"
                        android:text="요청 등록"
                        android:textColor="@color/primaryBlack"
                        android:textSize="@dimen/content_18" />

                    <Button
                        android:id="@+id/btn_home_add_incident"
                        android:layout_width="0dp"
                        android:layout_height="96dp"
                        android:layout_marginStart="@dimen/margin_8dp"
                        android:layout_weight="1"
                        android:backgroundTint="@color/white"
                        android:drawableTop="@android:drawable/ic_input_add"
                        android:drawableTint="@color/primaryGray"
                        android:fontFamily="@font/pretendard_semibold"
                        android:text="장애 등록"
                        android:textColor="@color/primaryBlack"
                        android:textSize="@dimen/content_18" />
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>
</layout>
