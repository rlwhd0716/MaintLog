<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="com.github.domain.model.common.StatusType" />

        <variable
            name="vm"
            type="com.github.maintlog_android.view.main.MainViewModel" />
    </data>

    <FrameLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/colorBackground"
            android:orientation="vertical"
            tools:context=".view.home.HomeFragment">

            <include
                android:id="@+id/layoutTopSearchBar"
                layout="@layout/layout_top_search_bar" />

            <androidx.core.widget.NestedScrollView
                android:id="@+id/nsvHome"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true"
                android:overScrollMode="never">

                <LinearLayout
                    android:id="@+id/llHome"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="12dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="96dp">

                    <!-- 날씨 카드 -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cvWeather"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/colorSurface"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:strokeColor="@color/colorBorder"
                        app:strokeWidth="1dp">

                        <include layout="@layout/layout_weather_card" />

                    </com.google.android.material.card.MaterialCardView>

                    <!-- 최근 장애 -->
                    <LinearLayout
                        android:id="@+id/section_recent_incidents"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:id="@+id/layout_recent_incidents_title_area"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackgroundBorderless"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/tv_recent_incidents_title"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/pretendard_semibold"
                                    android:text="최근 장애"
                                    android:textColor="@color/colorTextPrimary"
                                    android:textSize="@dimen/content_22" />

                                <ImageView
                                    android:id="@+id/iv_recent_incidents_arrow"
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_marginStart="4dp"
                                    android:src="@drawable/ic_arrow_right"
                                    app:tint="@color/colorTextPrimary" />
                            </LinearLayout>
                        </LinearLayout>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/card_recent_incident"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            app:cardBackgroundColor="@color/colorSurface"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="2dp"
                            app:strokeColor="@color/colorBorder"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <!-- 좌측 장애 강조 Bar -->
                                <View
                                    android:id="@+id/view_incident_accent"
                                    android:layout_width="6dp"
                                    android:layout_height="match_parent"
                                    android:background="@color/colorError" />

                                <!-- 기존 카드 내용 -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:padding="16dp">

                                    <!-- 상단 -->
                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:gravity="center_vertical"
                                        android:orientation="horizontal">

                                        <!-- 상태 라벨 유지 -->
                                        <com.github.maintlog_android.view.common.StatusBadgeView
                                            android:id="@+id/tv_incident_status"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            app:statusType="@{StatusType.ACTION}" />

                                        <!-- 제목 -->
                                        <TextView
                                            android:id="@+id/tv_incident_title"
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:layout_marginStart="8dp"
                                            android:layout_weight="1"
                                            android:ellipsize="end"
                                            android:fontFamily="@font/pretendard_semibold"
                                            android:maxLines="1"
                                            android:text="서버 다운 장애"
                                            android:textColor="@color/colorTextPrimary"
                                            android:textSize="@dimen/content_18" />

                                        <!-- 일시 -->
                                        <TextView
                                            android:id="@+id/tv_incident_date"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginStart="8dp"
                                            android:fontFamily="@font/pretendard_medium"
                                            android:text="10분 경과"
                                            android:textColor="@color/colorTextSecondary"
                                            android:textSize="@dimen/content_12" />

                                    </LinearLayout>

                                    <!-- 하단 -->
                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="12dp"
                                        android:gravity="center_vertical"
                                        android:orientation="horizontal">

                                        <!-- 내용 -->
                                        <TextView
                                            android:id="@+id/tv_incident_description"
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:layout_weight="1"
                                            android:ellipsize="end"
                                            android:fontFamily="@font/pretendard_medium"
                                            android:maxLines="2"
                                            android:minLines="2"
                                            android:text="DB 연결 실패로 인해 일부 서비스 접근이 불가능한 상태입니다."
                                            android:textColor="@color/colorTextSecondary"
                                            android:textSize="@dimen/content_14" />

                                        <!-- 상세 버튼 -->
                                        <ImageView
                                            android:id="@+id/iv_incident_arrow"
                                            android:layout_width="18dp"
                                            android:layout_height="18dp"
                                            android:layout_marginStart="12dp"
                                            android:src="@drawable/ic_arrow_right"
                                            app:tint="@color/colorTextSecondary" />

                                    </LinearLayout>
                                </LinearLayout>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <!-- 최근 요청사항 -->
                    <LinearLayout
                        android:id="@+id/section_recent_requests"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <!-- 제목 영역: 클릭 시 요청사항 목록 이동 -->
                            <LinearLayout
                                android:id="@+id/layout_recent_requests_title_area"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackgroundBorderless"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/tv_recent_requests_title"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/pretendard_semibold"
                                    android:text="최근 요청사항"
                                    android:textColor="@color/colorTextPrimary"
                                    android:textSize="@dimen/content_22" />

                                <ImageView
                                    android:id="@+id/iv_recent_requests_arrow"
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_marginStart="4dp"
                                    android:src="@drawable/ic_arrow_right"
                                    app:tint="@color/colorTextPrimary" />

                            </LinearLayout>

                            <!-- 요청사항 요약 Chip -->
                            <LinearLayout
                                android:id="@+id/layout_request_summary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <!-- 진행 -->
                                <LinearLayout
                                    android:id="@+id/chip_request_progress"
                                    android:layout_width="wrap_content"
                                    android:layout_height="28dp"
                                    android:layout_marginEnd="4dp"
                                    android:background="@drawable/bg_chip_info"
                                    android:gravity="center"
                                    android:orientation="horizontal"
                                    android:paddingStart="8dp"
                                    android:paddingEnd="8dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="@font/pretendard_medium"
                                        android:includeFontPadding="false"
                                        android:text="진행"
                                        android:textColor="@color/colorInfo"
                                        android:textSize="@dimen/content_12" />

                                    <TextView
                                        android:id="@+id/tv_request_progress_count"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="4dp"
                                        android:fontFamily="@font/pretendard_semibold"
                                        android:includeFontPadding="false"
                                        android:text="5"
                                        android:textColor="@color/colorInfo"
                                        android:textSize="@dimen/content_12" />

                                </LinearLayout>

                                <!-- 완료 -->
                                <LinearLayout
                                    android:id="@+id/chip_request_complete"
                                    android:layout_width="wrap_content"
                                    android:layout_height="28dp"
                                    android:layout_marginEnd="4dp"
                                    android:background="@drawable/bg_chip_success"
                                    android:gravity="center"
                                    android:orientation="horizontal"
                                    android:paddingStart="8dp"
                                    android:paddingEnd="8dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="@font/pretendard_medium"
                                        android:includeFontPadding="false"
                                        android:text="완료"
                                        android:textColor="@color/colorSuccess"
                                        android:textSize="@dimen/content_12" />

                                    <TextView
                                        android:id="@+id/tv_request_complete_count"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="4dp"
                                        android:fontFamily="@font/pretendard_semibold"
                                        android:includeFontPadding="false"
                                        android:text="2"
                                        android:textColor="@color/colorSuccess"
                                        android:textSize="@dimen/content_12" />

                                </LinearLayout>

                                <!-- 보류 -->
                                <LinearLayout
                                    android:id="@+id/chip_request_hold"
                                    android:layout_width="wrap_content"
                                    android:layout_height="28dp"
                                    android:background="@drawable/bg_chip_neutral"
                                    android:gravity="center"
                                    android:orientation="horizontal"
                                    android:paddingStart="8dp"
                                    android:paddingEnd="8dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="@font/pretendard_medium"
                                        android:includeFontPadding="false"
                                        android:text="보류"
                                        android:textColor="@color/colorNeutral"
                                        android:textSize="@dimen/content_12" />

                                    <TextView
                                        android:id="@+id/tv_request_hold_count"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="4dp"
                                        android:fontFamily="@font/pretendard_semibold"
                                        android:includeFontPadding="false"
                                        android:text="1"
                                        android:textColor="@color/colorNeutral"
                                        android:textSize="@dimen/content_12" />

                                </LinearLayout>

                            </LinearLayout>

                        </LinearLayout>

                        <!-- Request List Card -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/card_recent_requests"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            app:cardBackgroundColor="@color/colorSurface"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="2dp"
                            app:strokeColor="@color/colorBorder"
                            app:strokeWidth="1dp">

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rv_recent_requests"
                                bindAdapter="@{vm.improvementActionList}"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:adapter="@{vm.homeActionAdapter}"
                                android:clipToPadding="false"
                                android:paddingTop="4dp"
                                android:paddingBottom="4dp"
                                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                                tools:itemCount="5"
                                tools:listitem="@layout/item_home_action" />

                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </LinearLayout>

        <!-- 통합 검색 오버레이 -->
        <include
            android:id="@+id/layoutSearchOverlay"
            layout="@layout/layout_search_overlay"
            android:visibility="gone" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_home_add"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|bottom"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="24dp"
            android:contentDescription="등록"
            android:src="@drawable/ic_add"
            app:backgroundTint="@color/colorPrimary"
            app:tint="@color/white" />
    </FrameLayout>
</layout>
