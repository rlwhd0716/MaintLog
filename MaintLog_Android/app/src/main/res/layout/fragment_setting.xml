<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:orientation="vertical"
        tools:context=".view.main.MainActivity">

        <com.github.util.ui.CustomTitleView
            android:id="@+id/title_setting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:itemTitleText="설정" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll_setting"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/container_setting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/padding_16dp"
                android:paddingTop="@dimen/padding_16dp">

                <LinearLayout
                    android:id="@+id/item_setting_notification"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_setting_notification_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/pretendard_semibold"
                        android:text="알림 설정"
                        android:textColor="@color/primaryBlack"
                        android:textSize="@dimen/content_20" />

                    <TextView
                        android:id="@+id/tv_setting_notification_arrow"
                        android:layout_width="32dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/pretendard_semibold"
                        android:gravity="end"
                        android:text=">"
                        android:textColor="@color/primaryGray"
                        android:textSize="@dimen/content_24" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/primaryLightGray" />

                <LinearLayout
                    android:id="@+id/item_setting_account"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_setting_account_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/pretendard_semibold"
                        android:text="계정 관리"
                        android:textColor="@color/primaryBlack"
                        android:textSize="@dimen/content_20" />

                    <TextView
                        android:id="@+id/tv_setting_account_arrow"
                        android:layout_width="32dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/pretendard_semibold"
                        android:gravity="end"
                        android:text=">"
                        android:textColor="@color/primaryGray"
                        android:textSize="@dimen/content_24" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/primaryLightGray" />

                <LinearLayout
                    android:id="@+id/item_setting_language"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_setting_language_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/pretendard_semibold"
                        android:text="언어 설정"
                        android:textColor="@color/primaryBlack"
                        android:textSize="@dimen/content_20" />

                    <TextView
                        android:id="@+id/tv_setting_language_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/margin_12dp"
                        android:text="한국어"
                        android:textColor="@color/primaryDarkGray"
                        android:textSize="@dimen/content_16" />

                    <TextView
                        android:id="@+id/tv_setting_language_arrow"
                        android:layout_width="32dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/pretendard_semibold"
                        android:gravity="end"
                        android:text=">"
                        android:textColor="@color/primaryGray"
                        android:textSize="@dimen/content_24" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/primaryLightGray" />

                <LinearLayout
                    android:id="@+id/item_setting_backup"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_setting_backup_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/pretendard_semibold"
                        android:text="데이터 백업"
                        android:textColor="@color/primaryBlack"
                        android:textSize="@dimen/content_20" />

                    <TextView
                        android:id="@+id/tv_setting_backup_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/margin_12dp"
                        android:text="박민수"
                        android:textColor="@color/primaryDarkGray"
                        android:textSize="@dimen/content_16" />

                    <TextView
                        android:id="@+id/tv_setting_backup_arrow"
                        android:layout_width="32dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/pretendard_semibold"
                        android:gravity="end"
                        android:text=">"
                        android:textColor="@color/primaryGray"
                        android:textSize="@dimen/content_24" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/primaryLightGray" />

                <LinearLayout
                    android:id="@+id/item_setting_version"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_setting_version_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/pretendard_semibold"
                        android:text="버전 정보"
                        android:textColor="@color/primaryBlack"
                        android:textSize="@dimen/content_20" />

                    <TextView
                        android:id="@+id/tv_setting_version_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="v1.0.0"
                        android:textColor="@color/primaryDarkGray"
                        android:textSize="@dimen/content_16" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/primaryLightGray" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>
</layout>
