<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.github.maintlog_android.view.home.HomeFragment"
        android:label="home">
        <action
            android:id="@+id/action_homeFragment_to_improvementFragment"
            app:destination="@id/improvementFragment" />
        <action
            android:id="@+id/action_homeFragment_to_incidentFragment"
            app:destination="@id/incidentFragment" />
    </fragment>

    <fragment
        android:id="@+id/improvementFragment"
        android:name="com.github.maintlog_android.view.improvement.ImprovementFragment"
        android:label="improvement"/>

    <fragment
        android:id="@+id/incidentFragment"
        android:name="com.github.maintlog_android.view.incident.IncidentFragment"
        android:label="incident"/>

    <fragment
        android:id="@+id/statisticsFragment"
        android:name="com.github.maintlog_android.view.statistics.StatisticsFragment"
        android:label="statistics"/>

    <fragment
        android:id="@+id/settingFragment"
        android:name="com.github.maintlog_android.view.setting.SettingFragment"
        android:label="setting" />

</navigation>
