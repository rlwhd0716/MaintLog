<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="dialog"
            type="com.github.util.ui.selector.SelectDialog" />
    </data>

    <LinearLayout
        android:id="@+id/ll_select"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/pretendard_medium"
            android:textColor="@color/primaryGray"
            android:gravity="center"
            android:textSize="@dimen/title_12"
            android:layout_margin="8dp"
            android:text="@{dialog.title}" />

        <View
            android:background="@color/primaryLightGray"
            android:layout_height="1dp"
            android:layout_width="match_parent" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_select_dialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <View
            android:background="@color/primaryLightGray"
            android:layout_height="1dp"
            android:layout_width="match_parent" />

        <TextView
            android:id="@+id/btn_dialog_close"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:fontFamily="@font/pretendard_extrabold"
            android:gravity="center"
            android:background="@color/primaryColor"
            android:text="@string/common_close"
            android:textColor="@color/black"
            android:textSize="@dimen/title_20" />

    </LinearLayout>
</layout>